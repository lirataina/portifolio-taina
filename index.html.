<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="description" content="Tainá Santos — Gerente de Marketing com 8 anos de experiência. Especialista em Tráfego Pago, Social Media, Branding e E-commerce.">
<meta name="author" content="Tainá Santos">
<meta property="og:title" content="Tainá Santos | Gerente de Marketing & Estrategista Digital">
<meta property="og:description" content="Transformando estratégias em crescimento real para marcas.">
<meta property="og:type" content="website">
<title>Tainá Santos | Gerente de Marketing & Estrategista Digital</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<style>
/* ============================================
   RESET & VARIÁVEIS
   ============================================ */
:root {
  --bg: #0A0A0A;
  --bg2: #0F0F0F;
  --bg3: #141414;
  --gold: #D4AF37;
  --gold-l: #E8C766;
  --gold-grad: linear-gradient(135deg, #D4AF37 0%, #F0D77B 50%, #D4AF37 100%);
  --white: #FFFFFF;
  --txt: #F5F5F5;
  --txt2: #A0A0A0;
  --txt3: #555;
  --glass: rgba(255,255,255,0.04);
  --glass-b: rgba(255,255,255,0.08);
  --gold-b: rgba(212,175,55,0.25);
  --radius: 20px;
  --radius-sm: 12px;
  --t: 0.4s cubic-bezier(0.25,0.46,0.45,0.94);
  --t-slow: 0.7s cubic-bezier(0.25,0.46,0.45,0.94);
}
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth;scroll-padding-top:80px}
body{font-family:'Inter',sans-serif;background:var(--bg);color:var(--txt);line-height:1.7;overflow-x:hidden;-webkit-font-smoothing:antialiased}
h1,h2,h3,h4{font-family:'Poppins',sans-serif}
ul{list-style:none}
a{text-decoration:none;color:inherit;transition:var(--t)}

/* UTILITÁRIOS */
.container{max-width:1200px;margin:0 auto;padding:0 24px}
.section{padding:120px 0;position:relative}
.gold{background:var(--gold-grad);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.glass{background:var(--glass);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border:1px solid var(--glass-b);border-radius:var(--radius)}
.tag{display:inline-block;font-family:'Poppins';font-size:0.8rem;font-weight:600;color:var(--gold);text-transform:uppercase;letter-spacing:3px;margin-bottom:16px;padding:6px 18px;border:1px solid var(--gold-b);border-radius:50px;background:rgba(212,175,55,0.05)}
.sec-title{font-family:'Poppins';font-size:clamp(2rem,5vw,3.2rem);font-weight:700;letter-spacing:-1px;line-height:1.2}
.sec-head{text-align:center;margin-bottom:64px}
.sec-sub{margin-top:14px;color:var(--txt2);font-size:1.05rem}

/* ============================================
   NAVBAR
   ============================================ */
.navbar{position:fixed;top:0;left:0;width:100%;z-index:1000;padding:20px 0;transition:var(--t)}
.navbar.scrolled{background:rgba(10,10,10,0.85);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border-bottom:1px solid var(--glass-b);padding:14px 0}
.nav-inner{max-width:1200px;margin:0 auto;padding:0 24px;display:flex;justify-content:space-between;align-items:center}
.logo{font-family:'Poppins';font-size:1.3rem;font-weight:700;letter-spacing:1px;color:var(--white)}
.logo span{color:var(--gold)}
.nav-menu{display:flex;gap:32px}
.nav-menu a{color:var(--txt2);font-size:0.88rem;font-weight:500;position:relative}
.nav-menu a::after{content:'';position:absolute;bottom:-4px;left:0;width:0;height:2px;background:var(--gold-grad);transition:var(--t)}
.nav-menu a:hover{color:var(--white)}
.nav-menu a:hover::after{width:100%}
.hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;z-index:1001}
.hamburger span{width:25px;height:2px;background:var(--white);border-radius:2px;transition:var(--t)}
.hamburger.active span:nth-child(1){transform:translateY(7px) rotate(45deg)}
.hamburger.active span:nth-child(2){opacity:0}
.hamburger.active span:nth-child(3){transform:translateY(-7px) rotate(-45deg)}

/* ============================================
   HERO
   ============================================ */
.hero{min-height:100vh;display:flex;align-items:center;position:relative;overflow:hidden;padding:100px 0 60px}
.hero-bg{position:absolute;inset:0;background:radial-gradient(circle at 20% 50%,rgba(212,175,55,0.08) 0%,transparent 50%),radial-gradient(circle at 80% 20%,rgba(212,175,55,0.05) 0%,transparent 40%);z-index:0}
.hero-grid{max-width:1200px;margin:0 auto;padding:0 24px;display:grid;grid-template-columns:1.1fr 0.9fr;gap:60px;align-items:center;position:relative;z-index:1}
.hero-greet{font-family:'Poppins';font-size:1.1rem;color:var(--gold);margin-bottom:8px;letter-spacing:1px}
.hero-title{font-family:'Poppins';font-size:clamp(2.5rem,6vw,4.5rem);font-weight:800;letter-spacing:-2px;line-height:1;margin-bottom:16px;background:linear-gradient(180deg,#FFF 0%,#888 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.hero-type{font-family:'Poppins';font-size:clamp(1rem,2.5vw,1.4rem);font-weight:500;color:var(--gold);margin-bottom:24px;min-height:32px}
.cursor{animation:blink 1s infinite;color:var(--gold)}
@keyframes blink{0%,50%{opacity:1}51%,100%{opacity:0}}
.hero-desc{font-size:1.05rem;color:var(--txt2);margin-bottom:36px;max-width:500px;line-height:1.8}
.hero-btns{display:flex;flex-wrap:wrap;gap:16px}
.btn{display:inline-flex;align-items:center;gap:8px;padding:14px 28px;font-family:'Poppins';font-size:0.9rem;font-weight:500;border-radius:50px;transition:var(--t);cursor:pointer;border:none;position:relative;overflow:hidden}
.btn-primary{background:var(--gold-grad);color:#000;box-shadow:0 4px 24px rgba(212,175,55,0.3)}
.btn-primary:hover{transform:translateY(-3px);box-shadow:0 8px 32px rgba(212,175,55,0.5)}
.btn-wpp{background:#25D366;color:#fff;box-shadow:0 4px 24px rgba(37,211,102,0.2)}
.btn-wpp:hover{transform:translateY(-3px);box-shadow:0 8px 32px rgba(37,211,102,0.4)}
.btn-outline{background:transparent;color:var(--white);border:1px solid var(--glass-b)}
.btn-outline:hover{border-color:var(--gold);color:var(--gold);transform:translateY(-3px)}

/* FOTO HERO */
.hero-photo{position:relative;display:flex;justify-content:center;align-items:center}
.photo-wrap{position:relative;width:380px;height:380px;max-width:100%}
.photo-ring{position:absolute;inset:-14px;border-radius:50%;background:conic-gradient(from 0deg,var(--gold),transparent,var(--gold),transparent,var(--gold));animation:rotate 8s linear infinite;opacity:0.5}
@keyframes rotate{to{transform:rotate(360deg)}}
.photo-inner{position:absolute;inset:0;border-radius:50%;overflow:hidden;border:4px solid var(--bg);background:linear-gradient(135deg,#1a1a1a,#0A0A0A)}
.photo-inner img{width:100%;height:100%;object-fit:cover}
.photo-ph{width:100%;height:100%;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:8px;font-family:'Poppins';color:var(--txt3)}
.photo-ph svg{opacity:0.3}

/* BADGES */
.badge{position:absolute;display:flex;align-items:center;gap:10px;padding:12px 18px;background:rgba(10,10,10,0.85);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border:1px solid var(--glass-b);border-radius:var(--radius-sm);animation:float 3s ease-in-out infinite}
.badge-1{top:12%;left:-30px}
.badge-2{bottom:12%;right:-30px;animation-delay:1.5s}
.badge b{display:block;font-family:'Poppins';font-size:0.95rem;color:var(--white)}
.badge small{font-size:0.72rem;color:var(--txt2)}
@keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-12px)}}

/* SCROLL INDICATOR */
.scroll-ind{position:absolute;bottom:30px;left:50%;transform:translateX(-50%);display:flex;flex-direction:column;align-items:center;gap:8px;color:var(--txt3);font-size:0.78rem}
.mouse{width:24px;height:38px;border:2px solid var(--txt3);border-radius:12px;display:flex;justify-content:center;padding-top:6px}
.wheel{width:4px;height:8px;background:var(--gold);border-radius:2px;animation:scrollWheel 2s infinite}
@keyframes scrollWheel{0%{opacity:1;transform:translateY(0)}100%{opacity:0;transform:translateY(12px)}}

/* ============================================
   SOBRE
   ============================================ */
.sobre-grid{display:grid;grid-template-columns:1.2fr 1fr;gap:60px;align-items:start}
.sobre-lead{font-size:1.15rem;color:var(--txt);margin-bottom:20px}
.sobre-text p{color:var(--txt2);margin-bottom:16px}
.sobre-text strong{color:var(--white)}
.sobre-skills{padding:32px}
.skills-title{font-family:'Poppins';font-size:1.1rem;margin-bottom:20px;color:var(--white)}
.skills-tags{display:flex;flex-wrap:wrap;gap:10px}
.skill-tag{padding:8px 16px;font-size:0.83rem;color:var(--txt);background:rgba(212,175,55,0.08);border:1px solid var(--gold-b);border-radius:50px;transition:var(--t);cursor:default}
.skill-tag:hover{background:rgba(212,175,55,0.15);border-color:var(--gold);transform:translateY(-2px)}

/* ============================================
   NÚMEROS
   ============================================ */
.numeros{background:var(--bg2)}
.numeros-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:24px}
.num-card{padding:40px 24px;text-align:center;transition:var(--t)}
.num-card:hover{transform:translateY(-6px);border-color:var(--gold-b);background:rgba(212,175,55,0.04)}
.num-icon{font-size:2rem;margin-bottom:12px}
.num-val{font-family:'Poppins';font-size:clamp(2rem,4vw,3rem);font-weight:800;background:var(--gold-grad);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;line-height:1}
.num-label{margin-top:8px;color:var(--txt2);font-size:0.88rem}

/* ============================================
   ESPECIALIDADES
   ============================================ */
.esp-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:20px}
.esp-card{padding:32px 20px;text-align:center;transition:var(--t);cursor:default}
.esp-card:hover{transform:translateY(-6px);border-color:var(--gold-b);background:rgba(212,175,55,0.04)}
.esp-icon{font-size:2rem;display:block;margin-bottom:12px;transition:var(--t)}
.esp-card:hover .esp-icon{transform:scale(1.2)}
.esp-card h3{font-family:'Poppins';font-size:0.9rem;font-weight:500;color:var(--txt)}

/* ============================================
   SERVIÇOS
   ============================================ */
.svc-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
.svc-card{padding:36px 28px;transition:var(--t);cursor:default}
.svc-card:hover{transform:translateY(-6px);border-color:var(--gold-b);background:rgba(212,175,55,0.04)}
.svc-num{font-family:'Poppins';font-size:0.85rem;font-weight:600;color:var(--gold);margin-bottom:12px;display:block}
.svc-card h3{font-family:'Poppins';font-size:1.15rem;font-weight:600;color:var(--white);margin-bottom:10px}
.svc-card p{color:var(--txt2);font-size:0.92rem}

/* ============================================
   TIMELINE
   ============================================ */
.timeline{max-width:800px;margin:0 auto;position:relative;padding-left:40px}
.timeline::before{content:'';position:absolute;left:8px;top:0;bottom:0;width:2px;background:linear-gradient(180deg,var(--gold),transparent)}
.tl-item{position:relative;margin-bottom:48px}
.tl-item:last-child{margin-bottom:0}
.tl-dot{position:absolute;left:-40px;top:24px;width:18px;height:18px;border-radius:50%;background:var(--bg);border:3px solid var(--gold);box-shadow:0 0 12px rgba(212,175,55,0.4)}
.tl-content{padding:28px 32px;transition:var(--t)}
.tl-content:hover{border-color:var(--gold-b);transform:translateX(6px)}
.tl-date{display:inline-block;font-family:'Poppins';font-size:0.75rem;font-weight:600;color:var(--gold);text-transform:uppercase;letter-spacing:2px;margin-bottom:8px}
.tl-content h3{font-family:'Poppins';font-size:1.3rem;font-weight:600;margin-bottom:6px;color:var(--white)}
.tl-company{color:var(--gold);font-size:0.95rem;margin-bottom:10px;font-weight:500}
.tl-content p{color:var(--txt2);font-size:0.92rem;margin-bottom:14px}
.tl-tags{display:flex;flex-wrap:wrap;gap:8px}
.tl-tags span{padding:4px 12px;font-size:0.73rem;color:var(--gold);background:rgba(212,175,55,0.08);border-radius:50px}

/* ============================================
   PORTFÓLIO
   ============================================ */
.pf-filters{display:flex;justify-content:center;flex-wrap:wrap;gap:12px;margin-bottom:40px}
.f-btn{padding:8px 20px;font-family:'Poppins';font-size:0.83rem;font-weight:500;color:var(--txt2);background:transparent;border:1px solid var(--glass-b);border-radius:50px;cursor:pointer;transition:var(--t)}
.f-btn:hover{color:var(--white);border-color:var(--gold-b)}
.f-btn.active{color:#000;background:var(--gold-grad);border-color:transparent}
.pf-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px}
.pf-item{aspect-ratio:4/3;border-radius:var(--radius);overflow:hidden;position:relative;cursor:pointer;background:linear-gradient(135deg,#1a1a1a,#111);border:1px solid var(--glass-b);transition:var(--t)}
.pf-item:hover{transform:translateY(-6px);border-color:var(--gold-b);box-shadow:0 12px 40px rgba(0,0,0,0.4)}
.pf-overlay{position:absolute;inset:0;padding:28px;display:flex;flex-direction:column;justify-content:flex-end;background:linear-gradient(180deg,transparent 30%,rgba(10,10,10,0.95) 100%);transition:var(--t)}
.pf-item:hover .pf-overlay{background:linear-gradient(180deg,rgba(10,10,10,0.4) 0%,rgba(10,10,10,0.95) 100%)}
.pf-cat{font-family:'Poppins';font-size:0.73rem;color:var(--gold);text-transform:uppercase;letter-spacing:2px;margin-bottom:6px}
.pf-overlay h3{font-family:'Poppins';font-size:1.15rem;font-weight:600;color:var(--white);margin-bottom:4px}
.pf-overlay p{font-size:0.83rem;color:var(--txt2);opacity:0;transform:translateY(10px);transition:var(--t)}
.pf-item:hover .pf-overlay p{opacity:1;transform:translateY(0)}
.pf-item.hidden{display:none}

/* ============================================
   FERRAMENTAS
   ============================================ */
.tools{background:var(--bg2)}
.tools-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:20px}
.tool-card{padding:28px 16px;text-align:center;transition:var(--t);cursor:default}
.tool-card:hover{transform:translateY(-6px);border-color:var(--gold-b);background:rgba(212,175,55,0.04)}
.tool-icon{font-size:2.2rem;margin-bottom:10px;transition:var(--t)}
.tool-card:hover .tool-icon{transform:scale(1.15)}
.tool-card span{font-family:'Poppins';font-size:0.83rem;font-weight:500;color:var(--txt)}

/* ============================================
   DIFERENCIAIS
   ============================================ */
.dif-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:20px}
.dif-card{padding:36px 24px;text-align:center;transition:var(--t);cursor:default}
.dif-card:hover{transform:translateY(-6px);border-color:var(--gold-b);background:rgba(212,175,55,0.04)}
.dif-icon{font-size:2.2rem;margin-bottom:14px;transition:var(--t)}
.dif-card:hover .dif-icon{transform:scale(1.2)}
.dif-card h3{font-family:'Poppins';font-size:1.05rem;font-weight:600;color:var(--white);margin-bottom:8px}
.dif-card p{font-size:0.85rem;color:var(--txt2);line-height:1.6}

/* ============================================
   CONTATO
   ============================================ */
.ct-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:20px}
.ct-card{padding:40px 24px;text-align:center;transition:var(--t);display:flex;flex-direction:column;align-items:center;gap:6px}
.ct-card:hover{transform:translateY(-6px);border-color:var(--gold-b);background:rgba(212,175,55,0.04)}
.ct-icon{width:60px;height:60px;display:flex;align-items:center;justify-content:center;border-radius:50%;background:rgba(212,175,55,0.1);color:var(--gold);margin-bottom:8px;transition:var(--t)}
.ct-card:hover .ct-icon{background:rgba(212,175,55,0.2);transform:scale(1.1)}
.ct-card h3{font-family:'Poppins';font-size:1rem;font-weight:600;color:var(--white)}
.ct-card span{font-size:0.83rem;color:var(--txt2)}

/* ============================================
   RODAPÉ
   ============================================ */
.footer{padding:40px 0;border-top:1px solid var(--glass-b);text-align:center}
.footer p{font-family:'Poppins';font-size:0.88rem;color:var(--txt3)}

/* ============================================
   WHATSAPP FLOAT
   ============================================ */
.wpp-float{position:fixed;bottom:30px;right:30px;width:56px;height:56px;background:#25D366;color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;z-index:999;box-shadow:0 4px 20px rgba(37,211,102,0.4);transition:var(--t);animation:pulseWpp 2s infinite}
.wpp-float:hover{transform:scale(1.1);box-shadow:0 6px 30px rgba(37,211,102,0.6)}
@keyframes pulseWpp{0%,100%{box-shadow:0 4px 20px rgba(37,211,102,0.4)}50%{box-shadow:0 4px 20px rgba(37,211,102,0.4),0 0 0 12px rgba(37,211,102,0)}}

/* ============================================
   REVEAL
   ============================================ */
.reveal{opacity:0;transform:translateY(40px);transition:opacity 0.7s ease,transform 0.7s ease}
.reveal.active{opacity:1;transform:translateY(0)}

/* ============================================
   RESPONSIVIDADE
   ============================================ */
@media(max-width:968px){
  .hero-grid{grid-template-columns:1fr;text-align:center;gap:40px}
  .hero-text{order:2}
  .hero-photo{order:1}
  .hero-desc{margin-left:auto;margin-right:auto}
  .hero-btns{justify-content:center}
  .sobre-grid{grid-template-columns:1fr;gap:32px}
  .numeros-grid{grid-template-columns:repeat(2,1fr)}
  .esp-grid{grid-template-columns:repeat(3,1fr)}
  .svc-grid{grid-template-columns:repeat(2,1fr)}
  .pf-grid{grid-template-columns:repeat(2,1fr)}
  .tools-grid{grid-template-columns:repeat(4,1fr)}
  .dif-grid{grid-template-columns:repeat(2,1fr)}
  .ct-grid{grid-template-columns:repeat(2,1fr)}
  .photo-wrap{width:280px;height:280px}
}
@media(max-width:640px){
  .section{padding:80px 0}
  .nav-menu{position:fixed;top:0;right:-100%;width:75%;height:100vh;background:rgba(10,10,10,0.98);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);flex-direction:column;justify-content:center;align-items:center;gap:28px;transition:right 0.4s ease;border-left:1px solid var(--glass-b)}
  .nav-menu.active{right:0}
  .nav-menu a{font-size:1.1rem}
  .hamburger{display:flex}
  .hero{padding:120px 0 40px}
  .hero-btns{flex-direction:column;width:100%}
  .btn{justify-content:center;width:100%}
  .photo-wrap{width:220px;height:220px}
  .badge{display:none}
  .scroll-ind{display:none}
  .numeros-grid{grid-template-columns:1fr}
  .esp-grid{grid-template-columns:repeat(2,1fr)}
  .svc-grid{grid-template-columns:1fr}
  .pf-grid{grid-template-columns:1fr}
  .tools-grid{grid-template-columns:repeat(3,1fr)}
  .dif-grid{grid-template-columns:1fr}
  .ct-grid{grid-template-columns:1fr}
  .timeline{padding-left:30px}
  .tl-dot{left:-30px}
  .tl-content{padding:20px}
  .wpp-float{width:48px;height:48px;bottom:20px;right:20px}
}
@media(max-width:380px){
  .esp-grid{grid-template-columns:1fr}
  .tools-grid{grid-template-columns:repeat(2,1fr)}
}
</style>
</head>
<body>

<!-- ========== NAVBAR ========== -->
<nav class="navbar" id="navbar">
  <div class="nav-inner">
    <a href="#hero" class="logo">TAINÁ<span>SANTOS</span></a>
    <ul class="nav-menu" id="navMenu">
      <li><a href="#hero">Início</a></li>
      <li><a href="#sobre">Sobre</a></li>
      <li><a href="#numeros">Números</a></li>
      <li><a href="#especialidades">Especialidades</a></li>
      <li><a href="#servicos">Serviços</a></li>
      <li><a href="#experiencia">Experiência</a></li>
      <li><a href="#portfolio">Portfólio</a></li>
      <li><a href="#ferramentas">Ferramentas</a></li>
      <li><a href="#diferenciais">Diferenciais</a></li>
      <li><a href="#contato">Contato</a></li>
    </ul>
    <div class="hamburger" id="hamburger"><span></span><span></span><span></span></div>
  </div>
</nav>

<!-- ========== HERO ========== -->
<section class="hero" id="hero">
  <div class="hero-bg"></div>
  <div class="hero-grid">
    <div class="hero-text">
      <p class="hero-greet">Olá, eu sou</p>
      <h1 class="hero-title">TAINÁ SANTOS</h1>
      <div class="hero-type"><span id="typed"></span><span class="cursor">|</span></div>
      <p class="hero-desc">Com mais de 8 anos de experiência em marketing digital, uno estratégia, criatividade e dados para fortalecer marcas, aumentar vendas e construir presença digital que converte.</p>
      <div class="hero-btns">
